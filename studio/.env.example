# ==============================================================================
# SANITY STUDIO - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual credentials
# 3. Get credentials from: https://sanity.io/manage
#
# ==============================================================================

# ==============================================================================
# SANITY STUDIO CONFIGURATION
# ==============================================================================
# Get from: https://sanity.io/manage/project/YOUR_PROJECT_ID
SANITY_STUDIO_PROJECT_ID="your_project_id_here"
SANITY_STUDIO_DATASET="production"

# Optional: Preview URL for frontend (defaults to http://localhost:3000)
SANITY_STUDIO_PREVIEW_URL=""

# Optional: Custom studio host (for custom domains)
SANITY_STUDIO_STUDIO_HOST=""

# ==============================================================================
# NEXT.JS PUBLIC VARIABLES (Used by frontend)
# ==============================================================================
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id_here"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-11-26"
NEXT_PUBLIC_SANITY_STUDIO_URL="https://your-studio.sanity.studio"

# ==============================================================================
# SANITY API TOKENS
# ==============================================================================
# Get from: https://sanity.io/manage/project/YOUR_PROJECT_ID/api#tokens

# Read Token (Viewer permissions - for frontend queries)
SANITY_API_READ_TOKEN="your_read_token_here"

# Write Token (Editor permissions - for import scripts and admin)
SANITY_API_WRITE_TOKEN="your_write_token_here"

# Deploy Token (Deployer permissions - for npx sanity deploy)
SANITY_DEPLOY_TOKEN="your_deploy_token_here"

# ==============================================================================
# FIREBASE CONFIGURATION (Optional - if using Firebase with studio)
# ==============================================================================
# Get from: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app

NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id_here"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your_measurement_id_here"

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================