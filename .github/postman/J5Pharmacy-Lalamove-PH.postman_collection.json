              "pm.test('Price breakdown exists', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('priceBreakdown');",
              "    pm.expect(jsonData.data.priceBreakdown).to.have.property('total');",
              "    pm.expect(jsonData.data.priceBreakdown).to.have.property('currency');",
              "});",
              "",
              "// Log quotation details",
              "const response = pm.response.json();",
              "console.log('=== Quotation Created ===');",
              "console.log('Quotation ID:', response.data.quotationId);",
              "console.log('Service Type:', response.data.serviceType);",
              "console.log('Total Price:', response.data.priceBreakdown.total, response.data.priceBreakdown.currency);",
              "console.log('Expires At:', response.data.expiresAt);",
              "console.log('Distance:', response.data.distance.value, response.data.distance.unit);",
              "console.log('Sender Stop ID:', response.data.stops[0].stopId);",
              "console.log('Recipient Stop ID:', response.data.stops[1].stopId);"
            ]
          }
