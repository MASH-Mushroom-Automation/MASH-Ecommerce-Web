{
  "info": {
    "name": "J5 Pharmacy - Lalamove PH Integration",
    "description": "Complete Postman collection for testing Lalamove API integration with J5 Pharmacy e-commerce system. This collection includes all endpoints needed for delivery integration in the Philippines market.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "j5pharmacy"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// HMAC Signature Generation for Lalamove API",
          "const SECRET = pm.environment.get('secret');",
          "const API_KEY = pm.environment.get('apikey');",
          "const time = new Date().getTime().toString();",
          "",
          "// SPECIAL HANDLING FOR SCHEDULED QUOTATION (Test 3)",
          "// Generate scheduleAt timestamp BEFORE HMAC signature calculation",
          "const requestName = pm.info.requestName || '';",
          "if (requestName.includes('Scheduled') || requestName.includes('3.')) {",
          "    const now = new Date();",
          "    const scheduleAt = new Date(now.getTime() + 2 * 60 * 60 * 1000);",
          "    const scheduleAtISO = scheduleAt.toISOString();",
          "    pm.environment.set('scheduleAt', scheduleAtISO);",
          "    console.log('=== Scheduled Order Time Generation ===');",
          "    console.log('Schedule At (UTC):', scheduleAtISO);",
          "    console.log('Current Time (UTC):', now.toISOString());",
          "}",
          "",
          "// Get request details",
          "const method = pm.request.method;",
          "",
          "// Build path from request URL (handle both resolved and unresolved variables)",
          "let path = '';",
          "try {",
          "    // Try to get the path from the URL object",
          "    const urlObj = pm.request.url;",
          "    if (urlObj.path && Array.isArray(urlObj.path)) {",
          "        // Path is an array like ['v3', 'cities', '{{quotationId}}']",
          "        // CRITICAL: Resolve variables in path segments",
          "        const resolvedPath = urlObj.path.map(segment => pm.variables.replaceIn(segment));",
          "        path = '/' + resolvedPath.join('/');",
          "    } else {",
          "        // Fallback: parse from string and resolve variables",
          "        const urlString = pm.request.url.toString();",
          "        const resolvedUrl = pm.variables.replaceIn(urlString);",
          "        const parsedUrl = new URL(resolvedUrl);",
          "        path = parsedUrl.pathname;",
          "    }",
          "} catch (e) {",
          "    console.error('Error parsing URL:', e);",
          "    // Last resort: manually construct from path segments and resolve variables",
          "    if (pm.request.url.path) {",
          "        const resolvedPath = pm.request.url.path.map(segment => pm.variables.replaceIn(segment));",
          "        path = '/' + resolvedPath.join('/');",
          "    }",
          "}",
          "",
          "// Get body if exists and resolve Postman variables",
          "let body = '';",
          "if (pm.request.body && pm.request.body.mode === 'raw') {",
          "    // Get the raw body",
          "    let rawBody = pm.request.body.raw || '';",
          "    ",
          "    // Resolve all Postman variables in the body",
          "    // This replaces {{variableName}} with actual values from environment",
          "    body = pm.variables.replaceIn(rawBody);",
          "}",
          "",
          "// Create raw signature string - CRITICAL: Use exact format with \\r\\n",
          "const rawSignature = `${time}\\r\\n${method}\\r\\n${path}\\r\\n\\r\\n${body}`;",
          "",
          "// Generate HMAC SHA256 signature",
          "const signature = CryptoJS.HmacSHA256(rawSignature, SECRET).toString();",
          "",
          "// Create authorization token",
          "const token = `${API_KEY}:${time}:${signature}`;",
          "",
          "// Set authorization header",
          "pm.request.headers.add({",
          "    key: 'Authorization',",
          "    value: `hmac ${token}`",
          "});",
          "",
          "// Set Market header (critical for Lalamove API)",
          "pm.request.headers.add({",
          "    key: 'Market',",
          "    value: pm.environment.get('market')",
          "});",
          "",
          "// Set timestamp for reference",
          "pm.environment.set('timestamp', time);",
          "",
          "console.log('=== HMAC Signature Debug ===');",
          "console.log('Timestamp:', time);",
          "console.log('Method:', method);",
          "console.log('Path:', path);",
          "console.log('Body (first 200 chars):', body.substring(0, 200));",
          "console.log('Body Length:', body.length);",
          "console.log('Raw Signature String (escaped):', rawSignature.replace(/\\r/g, '\\\\r').replace(/\\n/g, '\\\\n').substring(0, 300));",
          "console.log('Secret (first 10 chars):', SECRET.substring(0, 10) + '...');",
          "console.log('Signature:', signature);",
          "console.log('API Key:', API_KEY);",
          "console.log('Authorization:', `hmac ${token}`);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Get City Info (Philippines)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has data array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "",
              "// Log available services",
              "const response = pm.response.json();",
              "console.log('=== Available Services in Philippines ===');",
              "response.data.forEach(city => {",
              "    console.log(`City: ${city.name} (${city.locode})`);",
              "    city.services.forEach(service => {",
              "        console.log(`  - ${service.key}: ${service.description}`);",
              "        if (service.specialRequests && service.specialRequests.length > 0) {",
              "            console.log('    Special Requests:');",
              "            service.specialRequests.forEach(sr => {",
              "                console.log(`      * ${sr.name}: ${sr.description}`);",
              "            });",
              "        }",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Market",
            "value": "{{market}}",
            "type": "text"
          },
          {
            "key": "Request-ID",
            "value": "{{$guid}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{host}}/v3/cities",
          "host": ["{{host}}"],
          "path": ["v3", "cities"]
        },
        "description": "Retrieve information about available cities, vehicle types, and special requests in the Philippines market. This is essential for understanding what services are available for your delivery integration."
      }
    },
    {
      "name": "2. Get Quotation (Immediate)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has quotationId', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('quotationId');",
              "    ",
              "    // Save quotationId for next requests",
              "    pm.environment.set('quotationId', jsonData.data.quotationId);",
