# ==============================================================================
# MASH E-COMMERCE - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env for local development
# 2. Copy this file to .env.local for Next.js local overrides
# 3. Replace all placeholder values with your actual credentials
# 4. NEVER commit .env files with real credentials to Git
#
# ==============================================================================

# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=development

# ==============================================================================
# BACKEND API CONFIGURATION
# ==============================================================================
# Local Development: http://localhost:30000/api/v1
# Production: https://api.mashmarket.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:30000/api/v1
NEXT_PUBLIC_API_ENDPOINT=http://localhost:30000
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_VERSION=v1

# Local Backend (for email features: registration, verification, password reset)
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:30000/api/v1
NEXT_PUBLIC_LOCAL_API_TIMEOUT=30000

# Email Service Environment: "local" | "production"
NEXT_PUBLIC_EMAIL_SERVICE_ENV=local

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_API_LOGGING=true

# ==============================================================================
# AUTHENTICATION
# ==============================================================================
NEXT_PUBLIC_AUTH_TOKEN_KEY=auth-token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=refreshToken

# ==============================================================================
# AI CHATBOT CONFIGURATION
# ==============================================================================
# Google Gemini API - Get from: https://makersuite.google.com/app/apikey
# Free tier: 60 requests/minute, 1500 requests/day
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API - Get from: https://huggingface.co/settings/tokens
# Fallback when Gemini quota is exceeded
NEXT_PUBLIC_HF_API_KEY=your_huggingface_api_key_here

# Chatbot Settings
NEXT_PUBLIC_CHATBOT_ENABLED=true
NEXT_PUBLIC_CHATBOT_MAX_MESSAGES_PER_MINUTE=10
NEXT_PUBLIC_CHATBOT_DEBUG=false

# ==============================================================================
# SANITY CMS
# ==============================================================================
# Dashboard: https://sanity.io/manage/project/YOUR_PROJECT_ID
# Get your project ID from Sanity dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-26
NEXT_PUBLIC_SANITY_STUDIO_URL=https://your-studio.sanity.studio
NEXT_PUBLIC_SANITY_USE_CDN=true
NEXT_PUBLIC_SANITY_REALTIME_ENABLED=false

# Sanity API Tokens - Get from: https://sanity.io/manage/project/YOUR_PROJECT_ID/api
SANITY_API_READ_TOKEN=your_read_token_here
SANITY_API_WRITE_TOKEN=your_write_token_here
SANITY_DEPLOY_TOKEN=your_deploy_token_here

# ==============================================================================
# FIREBASE
# ==============================================================================
# Console: https://console.firebase.google.com/
# Get credentials from: Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ==============================================================================
# GOOGLE ANALYTICS 4
# ==============================================================================
# Get from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==============================================================================
# GOOGLE MAPS API
# ==============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ==============================================================================
# LALAMOVE API (Delivery Service)
# ==============================================================================
# Sandbox (Testing): https://rest.sandbox.lalamove.com
# Production: https://rest.lalamove.com
# Get keys from: https://www.lalamove.com/ph/business

# Sandbox/Testing Environment
LALAMOVE_API_KEY=pk_test_your_test_key_here
LALAMOVE_API_SECRET=sk_test_your_test_secret_here
LALAMOVE_HOST=https://rest.sandbox.lalamove.com
LALAMOVE_MARKET=PH

# Production Environment (uncomment when ready)
# LALAMOVE_API_KEY=pk_prod_your_production_key_here
# LALAMOVE_API_SECRET=sk_prod_your_production_secret_here
# LALAMOVE_HOST=https://rest.lalamove.com
# LALAMOVE_MARKET=PH

# ==============================================================================
# GMAIL SMTP (Email Notifications)
# ==============================================================================
# Setup Instructions:
# 1. Enable 2-Factor Authentication on Gmail
# 2. Go to: Google Account > Security > App Passwords
# 3. Generate App Password for "Mail"
# 4. Use the 16-character password below
#
# Limit: 500 emails/day for regular Gmail accounts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=Your Business Name <your-email@gmail.com>

# ==============================================================================
# CLOUDINARY (Image Upload & Management)
# ==============================================================================
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# ==============================================================================
# PAYMONGO PAYMENT GATEWAY
# ==============================================================================
# Dashboard: https://dashboard.paymongo.com/developers
# Supports: GCash, GrabPay, Credit/Debit Cards, PayMaya, COD
# When keys are missing, system falls back to COD-only mode (no errors)

# LIVE Keys (for production)
# PAYMONGO_SECRET_KEY=sk_live_your_live_secret_key
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_live_your_live_public_key

# TEST Keys (for development/staging)
PAYMONGO_SECRET_KEY=sk_test_your_test_secret_key
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_your_test_public_key

# Webhook secret (set after creating webhook endpoint in PayMongo dashboard)
# PAYMONGO_WEBHOOK_SECRET=whsk_your_webhook_secret_here

# App URL for payment redirect callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
