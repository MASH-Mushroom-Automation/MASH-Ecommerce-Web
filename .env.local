# ==============================================================================
# MASH E-commerce Frontend - Local Development Configuration
# ==============================================================================
# 
# LOCAL DEVELOPMENT SETUP:
# 1. Backend Terminal: cd MASH-Backend && npm run start:dev
#    - Runs on http://localhost:4000 (configure PORT=4000 in backend .env)
# 2. Frontend Terminal: cd MASH-Ecommerce-Web && npm run dev  
#    - Runs on http://localhost:3000
#
# ==============================================================================

# Backend API Configuration
# IMPORTANT: Backend must run on port 4000 to avoid conflict with Next.js (port 3000)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_ENDPOINT=http://localhost:4000
NEXT_PUBLIC_API_TIMEOUT=30000

# Local Backend (for email-dependent features: registration, verification, password reset)
NEXT_PUBLIC_LOCAL_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_LOCAL_API_TIMEOUT=30000

# Email Service Environment (determines which backend to use for email features)
# Options: "local" | "production"
# Use "local" when production email service is not configured
NEXT_PUBLIC_EMAIL_SERVICE_ENV=local

# Feature Flags
# Set to 'false' to use real backend API, 'true' to use mock data
# ✅ SANITY CMS ENABLED - Changed to false to fetch from Sanity (xyq5fhxs)
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Authentication
NEXT_PUBLIC_AUTH_TOKEN_KEY=auth-token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=refreshToken

# Authentication (Clerk)
# Add your Clerk keys here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# API Configuration
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_ENABLE_API_LOGGING=true

# Sanity CMS - PP_Namias Free Project (gerattrr)
# ✅ MIGRATED from MASH CMS on Dec 6, 2025
# 🆓 Free tier: 20 user seats, 2 datasets, 250K API calls/month
# 📊 Usage Dashboard: https://sanity.io/manage/project/gerattrr/usage
# 🔗 Token Management: https://www.sanity.io/manage/project/gerattrr/api#tokens

