    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const appointments = $input.all();\nconst requestData = $('Webhook Trigger').first().json.body;\n\nconst formattedAppointments = appointments.map(item => {\n  const appt = item.json;\n  return {\n    appointmentId: appt._id,\n    buyerUid: appt.buyer_uid,\n    sellerUid: appt.seller_uid,\n    productType: appt.product_type,\n    quantity: appt.quantity_kg,\n    scheduledTime: appt.scheduled_time,\n    location: appt.location,\n    status: appt.status,\n    notes: appt.notes || '',\n    createdAt: appt.created_at,\n    updatedAt: appt.updated_at\n  };\n});\n\nconst response = {\n  success: true,\n  action: 'get_appointments',\n  userId: requestData.userId,\n  userType: requestData.userType,\n  appointments: formattedAppointments,\n  totalAppointments: formattedAppointments.length,\n  timestamp: new Date().toISOString()\n};\n\nreturn [response];"
      },
