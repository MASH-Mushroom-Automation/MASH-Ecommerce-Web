      "id": "query-appointments",
      "name": "Query Appointments",
      "type": "@n8n/n8n-nodes-langchain.googleFirestoreGetAllDocuments",
      "typeVersion": 1,
      "position": [700, 820],
      "credentials": {
        "googleFirestoreOAuth2Api": {
