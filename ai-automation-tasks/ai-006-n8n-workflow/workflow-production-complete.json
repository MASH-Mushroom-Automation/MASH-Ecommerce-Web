    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const appointment = $('Update Appointment to Cancelled').first().json;\nconst requestData = $('Webhook Trigger').first().json.body;\n\nconst response = {\n  success: true,\n  action: 'cancel_appointment',\n  appointmentId: requestData.appointmentId,\n  message: 'Appointment cancelled successfully. Time slot has been released.',\n  cancelledAt: new Date().toISOString(),\n  timestamp: new Date().toISOString()\n};\n\nreturn [response];"
      },
      "id": "format-cancel",
      "name": "Format Cancel Response",
