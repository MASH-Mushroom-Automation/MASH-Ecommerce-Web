    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama3.2:latest"
            },
            {
              "name": "prompt",
              "value": "=You are a seller matcher for MASH mushroom marketplace.\n\nBuyer request:\n- Product: {{ $('Webhook Trigger').first().json.body.productType }}\n- Quantity: {{ $('Webhook Trigger').first().json.body.quantity }}kg\n- Location: {{ $('Webhook Trigger').first().json.body.location }}\n- Preferred Date: {{ $('Webhook Trigger').first().json.body.preferredDate }}\n\nAvailable sellers:\n{{ $('Query Growers').all().map((item, index) => `${index + 1}. ${item.json.name} - ${item.json.specialty || 'All types'}. Location: ${item.json.location}. Capacity: ${item.json.capacity_kg || 'Unknown'}kg/week`).join('\\n') }}\n\nReturn ONLY a JSON array of the top 3 seller IDs ranked by relevance, like this:\n[\"seller_id_1\", \"seller_id_2\", \"seller_id_3\"]\n\nNo explanation, just the JSON array."
            },
            {
              "name": "stream",
              "value": false
            }
          ]
        },
        "options": {}
      },
      "id": "ollama-ai-match",
      "name": "Ollama AI Match",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1140, 240]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Get data from previous nodes\nconst growers = $('Query Growers').all();\nconst availabilitySlots = $('Query Availability').all();\nconst aiResponse = $('Ollama AI Match').first().json.response;\nconst requestData = $('Webhook Trigger').first().json.body;\n\n// Parse AI ranking\nlet topSellerIds = [];\ntry {\n  const match = aiResponse.match(/\\[.*?\\]/);\n  if (match) {\n    topSellerIds = JSON.parse(match[0]);\n  }\n} catch (e) {\n  // Fallback: return first 3 sellers\n  topSellerIds = growers.slice(0, 3).map(g => g.json._id || g.json.seller_uid);\n}\n\n// Build seller results with availability\nconst sellers = topSellerIds.slice(0, 3).map(sellerId => {\n  const grower = growers.find(g => (g.json._id === sellerId || g.json.seller_uid === sellerId));\n  if (!grower) return null;\n  \n  const sellerSlots = availabilitySlots\n    .filter(slot => slot.json.seller_uid === sellerId)\n    .slice(0, 3)\n    .map(slot => ({\n      slotId: slot.json._id || slot.json.slot_id,\n      date: slot.json.available_date,\n      startTime: slot.json.start_time,\n      endTime: slot.json.end_time,\n      duration: slot.json.duration_minutes\n    }));\n  \n  return {\n    id: sellerId,\n    name: grower.json.name,\n    specialty: grower.json.specialty || 'All mushroom types',\n    location: grower.json.location,\n    rating: grower.json.rating || 4.5,\n    capacity: grower.json.capacity_kg || 100,\n    availableSlots: sellerSlots\n  };\n}).filter(Boolean);\n\n// Format final response\nconst response = {\n  success: true,\n  action: 'find_sellers',\n  query: {\n    productType: requestData.productType,\n    quantity: requestData.quantity,\n    location: requestData.location,\n    preferredDate: requestData.preferredDate\n  },\n  sellers: sellers,\n  totalSellers: sellers.length,\n  timestamp: new Date().toISOString()\n};\n\nreturn [response];"
      },
      "id": "format-find-sellers",
      "name": "Format Find Sellers Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 240]
    },
    {
      "parameters": {
        "collection": "availability_slots",
        "filters": {
          "conditions": [
            {
              "field": "seller_uid",
              "operator": "==",
              "value": "={{ $('Webhook Trigger').first().json.body.sellerId }}"
            },
            {
              "field": "is_available",
              "operator": "==",
              "value": true
            },
            {
              "field": "available_date",
              "operator": ">=",
              "value": "={{ $now.format('yyyy-MM-dd') }}"
            }
          ]
        },
        "returnAll": true,
        "options": {
          "orderBy": [
            {
              "field": "available_date",
              "direction": "ASCENDING"
            },
            {
              "field": "start_time",
              "direction": "ASCENDING"
            }
          ]
        }
      },
      "id": "query-availability-slots",
      "name": "Query Availability Slots",
      "type": "@n8n/n8n-nodes-langchain.googleFirestoreGetAllDocuments",
      "typeVersion": 1,
      "position": [700, 380],
      "credentials": {
        "googleFirestoreOAuth2Api": {
          "id": "CREDENTIALS_PLACEHOLDER",
          "name": "Firebase MASH"
        }
      }
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const availabilitySlots = $input.all();\nconst requestData = $('Webhook Trigger').first().json.body;\nconst sellerId = requestData.sellerId;\nconst preferredDate = requestData.preferredDate;\n\n// Group slots by date\nconst slotsByDate = {};\navailabilitySlots.forEach(item => {\n  const slot = item.json;\n  const date = slot.available_date;\n  \n  if (!slotsByDate[date]) {\n    slotsByDate[date] = [];\n  }\n  \n  slotsByDate[date].push({\n    slotId: slot._id || slot.slot_id,\n    startTime: slot.start_time,\n    endTime: slot.end_time,\n    duration: slot.duration_minutes,\n    isAvailable: slot.is_available\n  });\n});\n\n// Filter by preferred date if provided\nlet filteredSlots = slotsByDate;\nif (preferredDate) {\n  filteredSlots = {};\n  if (slotsByDate[preferredDate]) {\n    filteredSlots[preferredDate] = slotsByDate[preferredDate];\n  }\n}\n\nconst response = {\n  success: true,\n  action: 'get_availability',\n  sellerId: sellerId,\n  preferredDate: preferredDate || null,\n  availabilityByDate: filteredSlots,\n  totalSlots: Object.values(filteredSlots).reduce((sum, slots) => sum + slots.length, 0),\n  dateRange: {\n    from: Object.keys(filteredSlots).sort()[0] || null,\n    to: Object.keys(filteredSlots).sort().reverse()[0] || null\n  },\n  timestamp: new Date().toISOString()\n};\n\nreturn [response];"
      },
      "id": "format-availability",
      "name": "Format Availability Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 380]
    },
