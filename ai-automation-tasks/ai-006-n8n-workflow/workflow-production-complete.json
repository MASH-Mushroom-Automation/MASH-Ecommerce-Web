    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const appointment = $('Create Appointment').first().json;\nconst requestData = $('Webhook Trigger').first().json.body;\n\nconst response = {\n  success: true,\n  action: 'set_appointment',\n  appointmentId: appointment.documentId,\n  appointment: {\n    buyerUid: requestData.buyerUid,\n    sellerUid: requestData.sellerUid,\n    productType: requestData.productType,\n    quantity: requestData.quantity,\n    scheduledTime: requestData.scheduledTime,\n    location: requestData.location,\n    status: 'pending',\n    notes: requestData.notes || '',\n    createdAt: new Date().toISOString()\n  },\n  message: 'Appointment created successfully. Seller will be notified.',\n  timestamp: new Date().toISOString()\n};\n\nreturn [response];"
      },
