[debug] [2026-01-30T16:22:58.362Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/mash-ddf8d/rulesets {"name":"projects/mash-ddf8d/rulesets/93f4ef5a-3af5-4205-823a-c9085d8855b5","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    \r\n    // ========================================\r\n    // HELPER FUNCTIONS\r\n    // ========================================\r\n    \r\n    // Check if user is authenticated\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n    \r\n    // Check if user owns the document\r\n    function isOwner(userId) {\r\n      return isSignedIn() && request.auth.uid == userId;\r\n    }\r\n    \r\n    // Check if user is admin/seller (from Firestore users collection)\r\n    function isAdmin() {\r\n      return isSignedIn() && \r\n             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\r\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SELLER', 'GROWER'];\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // USERS COLLECTION\r\n    // ========================================\r\n    match /users/{userId} {\r\n      // Anyone can read user profiles (needed for display names)\r\n      allow read: if true;\r\n      \r\n      // Users can create their own profile\r\n      allow create: if isSignedIn() && request.auth.uid == userId;\r\n      \r\n      // Users can update their own profile\r\n      allow update: if isOwner(userId);\r\n      \r\n      // Only admins can delete users\r\n      allow delete: if isAdmin();\r\n      \r\n      // Addresses subcollection\r\n      match /addresses/{addressId} {\r\n        // Users can only access their own addresses\r\n        allow read, write: if isOwner(userId);\r\n      }\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // ORDERS COLLECTION\r\n    // ========================================\r\n    \r\n    // GUEST CART & WISHLIST (Allow unauthenticated access)\r\n    // Required for guest users to add items before login\r\n    match /carts/{cartId} {\r\n      // Allow anyone to read/write their own cart (authenticated or guest)\r\n      allow read, write: if true;\r\n    }\r\n    \r\n    match /wishlists/{wishlistId} {\r\n      // Allow anyone to read/write their own wishlist (authenticated or guest)\r\n      allow read, write: if true;\r\n    }\r\n    \r\n    match /orders/{orderId} {\r\n      // Users can read their own orders\r\n      // Sellers/Admins can read all orders\r\n      allow read: if isSignedIn() && \r\n                     (resource.data.userId == request.auth.uid || isAdmin());\r\n      \r\n      // Users can create their own orders\r\n      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;\r\n      \r\n      // Users can update their own orders (for cancellation)\r\n      // Sellers/Admins can update any order (for status changes, approval)\r\n      allow update: if isSignedIn() && \r\n                       (resource.data.userId == request.auth.uid || isAdmin());\r\n      \r\n      // Only admins can delete orders\r\n      allow delete: if isAdmin();\r\n      \r\n      // TEMPORARY: Allow all authenticated users to list orders\r\n      // TODO: Implement proper role-based access control\r\n      allow list: if isSignedIn();\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // CARTS COLLECTION\r\n    // ========================================\r\n    match /carts/{userId} {\r\n      // Users can only access their own cart\r\n      allow read, write: if isOwner(userId);\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // WISHLISTS COLLECTION\r\n    // ========================================\r\n    match /wishlists/{userId} {\r\n      // Users can only access their own wishlist\r\n      allow read, write: if isOwner(userId);\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // NOTIFICATIONS COLLECTION\r\n    // ========================================\r\n    match /notifications/{notificationId} {\r\n      // Users can read their own notifications\r\n      // Admins can read all notifications\r\n      allow read: if isSignedIn() && \r\n                     (resource.data.userId == request.auth.uid || isAdmin());\r\n      \r\n      // Only system (via admin SDK) can create notifications\r\n      // But we'll allow admins to create notifications for testing\r\n      allow create: if isAdmin();\r\n      \r\n      // Users can update their own notifications (mark as read)\r\n      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;\r\n      \r\n      // Users can delete their own notifications\r\n      // Admins can delete any notification\r\n      allow delete: if isSignedIn() && \r\n                       (resource.data.userId == request.auth.uid || isAdmin());\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // PRODUCTS COLLECTION (if using Firestore)\r\n    // ========================================\r\n    match /products/{productId} {\r\n      // Anyone can read products\r\n      allow read: if true;\r\n      \r\n      // Only sellers/admins can create/update products\r\n      allow create, update: if isAdmin();\r\n      \r\n      // Only admins can delete products\r\n      allow delete: if isAdmin();\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // REVIEWS COLLECTION\r\n    // ========================================\r\n    match /reviews/{reviewId} {\r\n      // Anyone can read reviews\r\n      allow read: if true;\r\n      \r\n      // Authenticated users can create reviews\r\n      allow create: if isSignedIn();\r\n      \r\n      // Users can update/delete their own reviews\r\n      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // GROWERS/STORES COLLECTION\r\n    // ========================================\r\n    match /growers/{growerId} {\r\n      // Anyone can read grower info\r\n      allow read: if true;\r\n      \r\n      // Only admins can create/update/delete growers\r\n      allow write: if isAdmin();\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // CHATBOT ANALYTICS COLLECTIONS\r\n    // ========================================\r\n    \r\n    // Chatbot conversations - allow unauthenticated writes for guest users\r\n    match /chatbot_conversations/{conversationId} {\r\n      allow write: if true; // Allow guest users to track conversations\r\n      allow read: if isAdmin();\r\n    }\r\n    \r\n    // Chatbot queries - allow unauthenticated writes for guest users\r\n    match /chatbot_queries/{queryId} {\r\n      allow write: if true; // Allow guest users to log queries\r\n      allow read: if isAdmin();\r\n    }\r\n    \r\n    // Product clicks - allow unauthenticated writes for guest users\r\n    match /chatbot_product_clicks/{clickId} {\r\n      allow write: if true; // Allow guest users to track product clicks\r\n      allow read: if isAdmin();\r\n    }\r\n    \r\n    // Error logs - anyone can write (for guest users too), admins can read\r\n    match /chatbot_errors/{errorId} {\r\n      allow write: if true; // Allow guest users to log errors\r\n      allow read: if isAdmin();\r\n    }\r\n    \r\n    // ========================================\r\n    // ANALYTICS COLLECTION (Admin Only)\r\n    // ========================================\r\n    match /analytics/{document=**} {\r\n      allow read, write: if isAdmin();\r\n    }\r\n    \r\n    \r\n    // ========================================\r\n    // DEFAULT: DENY ALL\r\n    // ========================================\r\n    // Any collection not explicitly defined above is denied\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-01-30T16:23:04.251311Z","metadata":{"services":["cloud.firestore"]}}
